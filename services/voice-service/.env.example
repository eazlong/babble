ELEVENLABS_API_KEY=<your-key>

# F5-TTS (local MLX server, runs on Mac via: .venv/bin/python services/f5-tts-server/main.py)
FISH_SPEECH_URL=http://localhost:8002

# Local Whisper ASR (faster-whisper)
WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=int8
WHISPER_CACHE=/models/whisper
